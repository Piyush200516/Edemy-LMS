# Copy this to .env and fill in your values

PORT=4000

# MongoDB URI (get from MongoDB Atlas or local mongod)
MONGODB_URI=mongodb://localhost:27017/accounting_db
# Example Atlas: mongodb+srv://username:pass@cluster.mongodb.net/accounting_db

# PostgreSQL URI
POSTGRES_URI=postgresql://username:password@localhost:5432/accounting_db
# Format: postgresql://user:pass@host:port/database

